    integrity="sha512-TYfUH4Mbt6NcWkJI7RS5MoMqFSkpBCChADy2EjAiFr5ckAdTjOUUjnTA3GH8PQAIa2Nz7eR/4PR9xXY3uhnu/A=="
    crossorigin="anonymous"
  ></script>
  <script
    src="https://cdnjs.cloudflare.com/ajax/libs/datepair.js/0.4.17/jquery.datepair.min.js"
    integrity="sha512-dY39OLVn61yY3H9Iboby9hTzf4HyP7SdTuqPvWJzBmHqu+zbVQKEUPm+HmZT5/Mh9G/UV52nQ2PfcmG/OoRQdQ=="
    crossorigin="anonymous"
  ></script>
{% endblock %}
